{
  "manifest_version": 3,
  "name": "CyberPet Companion & Solana NFT Stable",
  "version": "1.0.0",
  "description": "A beautiful screen companion pet that tracks stats, levels up, and integrates with Solana Dynamic NFT Schemas.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://*.supabase.co/"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["config.js", "supabase.js", "pet_assets.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
