{
  "manifest_version": 3,
  "name": "DeskPet — Neon Cyber Companion RPG",
  "version": "2.0.0",
  "description": "Your neon cyber-companion RPG that lives on every webpage. Focus Timer (Pomodoro), NFT pets on Solana, PvP battles, breeding, staking expeditions & gear drops. Feed, train, and evolve your Tamagotchi-style pet while you browse.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "https://*.supabase.co/",
    "https://auth.privy.io/",
    "http://localhost:3001/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "assets/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DeskPet Control Panel",
    "default_icon": "assets/icon.png"
  },
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pet_assets.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "pet-engine.js", "privy-sdk.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
