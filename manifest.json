{
  "manifest_version": 3,
  "name": "DeskPet",
  "version": "1.1.0",
  "description": "Your glowing retro-neon pixel-art NFT pet that floats on your screen.",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.supabase.co/",
    "https://auth.privy.io/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "assets/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "DeskPet Control Panel",
    "default_icon": "assets/icon.png"
  },
  "options_ui": {
    "page": "dashboard.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pet_assets.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "pet-engine.js", "privy-sdk.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
